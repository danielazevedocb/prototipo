DATABASE_URL="postgresql://postgres:postgres@localhost:5432/prototipo?schema=public"

# Opcional para desenvolvimento local com SQLite:
# 1. Troque `provider = "postgresql"` por `provider = "sqlite"` em `prisma/schema.prisma`
# 2. Remova os atributos `@db.VarChar(...)` do schema
# 3. Use a URL abaixo no lugar da URL Postgres
# DATABASE_URL="file:./dev.db"
